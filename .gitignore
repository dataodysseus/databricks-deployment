# Terraform state files — never commit these
*.tfstate
*.tfstate.*
*.tfstate.backup
.terraform.tfstate.lock.info

# Terraform working directory
.terraform/
# NOTE: .terraform.lock.hcl is intentionally COMMITTED (pins provider versions).

# Variable files with real values (account IDs, SA emails, admin emails) — NEVER commit.
# Commit the *.tfvars.example templates instead; copy one to *.tfvars and fill in locally.
terraform.tfvars
*.auto.tfvars
*.tfvars
!*.tfvars.example

# Crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# GCP credentials
*.json
service-account-*.json
application_default_credentials.json

# macOS
.DS_Store
.AppleDouble
.LSOverride

# VS Code
.vscode/
*.code-workspace

# JetBrains
.idea/
*.iml
